# Backend Configuration

# Production mode toggle
NODE_ENV=development

# Server port
PORT=3000

# JWT Secret for token signing - generate a secure random string in production
# You can generate a new secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secure-random-secret-key-here-64-characters-minimum

# CORS - comma-separated list of allowed origins
# For development: http://localhost:3000,http://localhost:8081,http://localhost:19006
# For production: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006

# Database path
DB_PATH=./data/tata.db